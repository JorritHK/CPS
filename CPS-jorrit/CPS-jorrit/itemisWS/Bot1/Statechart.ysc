  <sgraph:Statechart xmi:id="_H3ZnkBtMEeuKLrIwlRh1BQ" specification="@EventDriven&#xA;@ChildFirstExecution&#xA;&#xA;&#xA;&#xA;&#xA;internal:&#xA;&#x9;// our custom interface&#xA;&#x9;var calibratedYaw:real&#xA;&#x9;var normalizedYaw:integer = 0&#xA;&#x9;&#xA;&#x9;const gridDirectionY = -1 // south&#xA;&#x9;const gridDirectionX = 1 // west&#xA;&#x9;var distanceToCenter: real&#xA;&#x9;&#xA;&#x9;var counter: integer =1 // thomas add&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;// custom operations&#xA;&#x9;operation abs_real(x: real): real&#xA;&#x9;operation ease_out_exp(distance: real, total_distance: real, exponent: integer): real&#xA;&#x9;&#xA;&#x9;operation debug(text: string)&#xA;&#x9;operation debug_real(name: string, value: real)&#xA;&#x9;operation debug_bool(name: string, value: boolean)&#xA;&#x9;&#xA;&#x9;operation grid_position_column(current_x: real): integer&#xA;&#x9;operation grid_position_row(current_y: real): integer&#xA;&#x9;operation calc_orientation(yaw: real): integer&#xA;&#x9;operation orientation_to_yaw(orientation: integer): real&#xA;&#x9;&#xA;&#x9;operation set_calibration(start_x: real, start_y: real, zero_south_degree: real, laser_deg_offset: real)&#xA;&#x9;operation relative_yaw(yaw: real): real&#xA;&#x9;operation calc_yaw_rotation(yawA: real, yawB: real): real&#xA;&#x9;operation distance_to_grid_center(current_x: real, current_y: real): real&#xA;&#x9;operation direction_has_wall(distance: real): integer&#xA;&#xA;&#x9;event newGridBox&#xA;&#xA;interface userVar:&#xA;    // userVar: not part of the robot interface.&#xA;    // You can modify this as you wish. &#xA;&#x9;var baseSpeed:real = 0.05&#xA;&#x9;var baseRotation:real = 0.2&#xA;&#x9;var startprocedure:boolean = true&#xA;&#x9;var hasCalibrated: boolean = false&#xA;&#xA;&#x9;var minWallDistance:real = 0.15&#xA;&#x9;var minWallTurn = 0.3&#xA;&#x9;var currentYaw = 0.0&#xA;&#x9;var afterTurnYaw = 0.0&#xA;&#x9;&#xA;&#x9;var targetYaw: real&#xA;&#x9;var yawToGo: real&#xA;&#x9;var totalYawToGo: real&#xA;&#x9;var yawError: real = 0.5&#xA;&#x9;var rotationDirection: integer = 1&#xA;&#x9;var totalDistanceToGo: real&#xA;&#x9;var distanceToGo: real&#xA;&#x9;var centerDistanceError: real = 0.04&#xA;&#x9;var lastDistance: real&#xA;&#x9;var lastYawToGo: real&#xA;&#x9;&#xA;&#x9;var panicModeEnable: boolean = false&#xA;&#x9;var mappingModeEnabled: boolean = true&#xA;&#x9;&#xA;&#x9;var maxRotation = baseRotation * 5&#xA;&#x9;&#xA;&#x9;&#xA;&#x9;var gridNewX: integer&#xA;&#x9;var gridNewY: integer&#xA;&#x9;&#xA;&#x9;var wallFront: integer&#xA;&#x9;var wallLeft: integer&#xA;&#x9;var wallRight: integer&#xA;&#x9;var wallBack: integer&#xA;&#x9;&#xA;&#x9;// thomas vars&#xA;&#x9;//var baseSpeed:real = 0.05&#xA;&#x9;//var baseRotation:real = 0.2&#xA;&#x9;//var startprocedure:boolean = true&#xA;&#x9;var odomFollowerX: real&#xA;&#x9;var odomFollowerY: real&#xA;&#x9;&#xA;&#x9;&#xA;&#xA;/////////////////////////////////////////////////////&#xA;// Robot Interface.&#xA;// Don't change anything below this line.&#xA;interface baseValues:&#xA;&#x9;var maxSpeed:real = 0.22&#xA;&#x9;var maxRotation:real = 2.84&#xA;&#x9;&#xA;&#x9;var degreesFront:integer = 10&#xA;&#x9;var degreesRight:integer = 10&#xA;&#x9;var degreesBack:integer = 10&#xA;&#x9;var degreesLeft:integer = 10&#xA;&#xA;&#xA;////////////////////////////////////////////////&#xA;// These values are output.&#xA;// The code sends these either &#xA;// to the TurtleBot3, or &#xA;// uses it within the code&#xA;interface output:&#xA;&#x9;var speed:real&#xA;&#x9;var rotation:real&#xA;&#x9;&#xA;&#x9;var obstacles:integer = 0&#xA;&#x9;var gems:integer = 0&#xA;&#x9;&#xA;&#x9;var finish:integer = 0&#xA;&#xA;////////////////////////////////////////////////&#xA;// Keeps track of variables &#xA;// in the grid&#xA;interface grid:&#xA;&#x9;var update:boolean = false&#xA;&#x9;var receive:boolean = false&#xA;&#x9;&#xA;&#x9;var column:integer = 0&#xA;&#x9;var row:integer = 0&#xA;&#x9;var orientation:integer&#xA;&#x9;&#xA;&#x9;var visited:boolean&#xA;&#x9;&#xA;&#x9;var wallFront:integer&#xA;&#x9;var wallRight:integer&#xA;&#x9;var wallBack:integer&#xA;&#x9;var wallLeft:integer&#xA;&#x9;&#xA;&#x9;var gridSize:real = 0.48&#xA;&#x9;var maxCol:integer = 3&#xA;&#x9;var maxRow:integer = 3&#xA;&#xA;////////////////////////////////////////////////&#xA;// Calibration variables&#xA;interface startPos:&#xA;&#x9;var setZero:boolean = false&#xA;&#x9;var zeroX:real&#xA;&#x9;var zeroY:real&#xA;&#x9;var zeroSouthDegree:real&#xA;&#x9;var laserDegOffset:integer&#xA;&#xA;&#xA;////////////////////////////////////////////////&#xA;// Keyboard input in the&#xA;// form of events&#xA;interface computer:&#xA;&#x9;in event m_press&#xA;&#x9;in event w_press&#xA;&#x9;in event a_press&#xA;&#x9;in event s_press&#xA;&#x9;in event d_press&#xA;&#x9;in event x_press&#xA;&#xA;////////////////////////////////////////////////&#xA;// The data from the IMU in&#xA;// Euler angles.&#xA;interface imu:&#xA;&#x9;var pitch:real&#xA;&#x9;var roll:real&#xA;&#x9;var yaw:real&#xA;&#xA;////////////////////////////////////////////////&#xA;// The data from the odometry in&#xA;// the x, y and z directions.&#xA;interface odom:&#xA;&#x9;var x:real&#xA;&#x9;var y:real&#xA;&#x9;var z:real&#xA;&#xA;////////////////////////////////////////////////&#xA;// Distance data from the &#xA;// LDS&#xA;interface laserDistance:&#xA;&#x9;var d0:real&#xA;&#x9;var d90:real&#xA;&#x9;var d180:real&#xA;&#x9;var dm90:real&#xA;&#x9;&#xA;&#x9;var dMin:real&#xA;&#x9;var minDeg:integer&#xA;&#x9;&#xA;&#x9;var dMax:real&#xA;&#x9;var maxDeg:integer&#xA;&#x9;&#xA;&#x9;var dMean:real&#xA;&#x9;&#xA;&#x9;var dFrontMin:real&#xA;&#x9;var minDegF:integer&#xA;&#x9;var dFrontMax:real&#xA;&#x9;var maxDegF:integer&#xA;&#x9;var dFrontMean:real&#xA;&#x9;&#xA;&#x9;var dRightMin:real&#xA;&#x9;var minDegR:integer&#xA;&#x9;var dRightMax:real&#xA;&#x9;var maxDegR:integer&#xA;&#x9;var dRightMean:real&#xA;&#x9;&#xA;&#x9;var dBackMin:real&#xA;&#x9;var minDegB:integer&#xA;&#x9;var dBackMax:real&#xA;&#x9;var maxDegB:integer&#xA;&#x9;var dBackMean:real&#xA;&#x9;&#xA;&#x9;var dLeftMin:real&#xA;&#x9;var minDegL:integer&#xA;&#x9;var dLeftMax:real&#xA;&#x9;var maxDegL:integer&#xA;&#x9;var dLeftMean:real&#xA;&#xA;////////////////////////////////////////////////&#xA;// Intensity data from the &#xA;// LDS&#xA;interface laserIntensity:&#xA;&#x9;var i0:real&#xA;&#x9;var i90:real&#xA;&#x9;var i180:real&#xA;&#x9;var im90:real&#xA;&#x9;&#xA;&#x9;var iFrontMin:real&#xA;&#x9;var iFrontMax:real&#xA;&#x9;var iFrontMean:real&#xA;&#x9;&#xA;&#x9;var iRightMin:real&#xA;&#x9;var iRightMax:real&#xA;&#x9;var iRightMean:real&#xA;&#x9;&#xA;&#x9;var iBackMin:real&#xA;&#x9;var iBackMax:real&#xA;&#x9;var iBackMean:real&#xA;&#x9;&#xA;&#x9;var iLeftMin:real&#xA;&#x9;var iLeftMax:real&#xA;&#x9;var iLeftMean:real" name="model">
