                      <vertices xsi:type="sgraph:State" xmi:id="_HxH8MK2GEe-JaN6pWGebAw" specification="entry / output.speed = 0.0; debug(&quot;Stop going forward&quot;);&#xA;&#x9;userVar.wallFront = direction_has_wall(laserDistance.d0);&#xA;&#x9;userVar.wallLeft = direction_has_wall(laserDistance.d90);&#xA;&#x9;userVar.wallBack = direction_has_wall(laserDistance.d180);&#xA;&#x9;userVar.wallRight = direction_has_wall(laserDistance.dm90);&#xA;&#x9;debug(&quot;Stopped - current walls&quot;);&#xA;&#x9;debug_real(&quot;wallFront&quot;, userVar.wallFront);&#xA;&#x9; debug_real(&quot;wallRight&quot;, userVar.wallRight);&#xA;&#x9; debug_real(&quot;wallBack&quot;, userVar.wallBack);&#xA;&#x9; debug_real(&quot;wallLeft&quot;, userVar.wallLeft)&#xA;&#xA;exit / grid.orientation = calc_orientation(imu.yaw)" name="Stop robot" incomingTransitions="_CXcyEK3kEe-JaN6pWGebAw _oYSowK3gEe-JaN6pWGebAw">
