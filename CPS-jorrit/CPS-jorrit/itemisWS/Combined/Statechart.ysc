              </vertices>
              <vertices xsi:type="sgraph:State" xmi:id="_TXNWrLL5Ee-qJsRUaIURBQ" specification="entry/output.rotation = userVar.baseRotation / 3" name="anti-clock" incomingTransitions="_EB0EgLL6Ee-qJsRUaIURBQ">
