                <outgoingTransitions xmi:id="_XWik4LL3Ee-qJsRUaIURBQ" specification="[laserDistance.maxDegB&lt;-90 &amp;&amp; laserDistance.maxDegB>-179]" target="_YSQpcLL7Ee-qJsRUaIURBQ"/>
